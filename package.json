{
  "name": "quantumgames",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "validate": "tsx scripts/validate-configs.ts",
    "build:games": "npm run validate && tsx scripts/register-games.ts && bash scripts/build-games.sh",
    "build": "npm run build:games && next build",
    "build:all": "git submodule update --init --recursive && npm run build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "add-game": "bash scripts/add-game.sh"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
